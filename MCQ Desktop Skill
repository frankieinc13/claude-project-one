Replace `<COURSE KEYWORD>` with a word from the course name (e.g. "law", "auditing", "accounting").

#### 0c-iii — Find and click the assignment's blue arrow button (scroll if needed)

> **CRITICAL: Always click the blue arrow button next to the assignment — NEVER click the assignment name/text link directly.**
> The blue arrow is the correct launch button for SmartBook assignments. Clicking the assignment name may navigate to a summary page instead of launching questions.

```javascript
(async () => {
  const d = ms => new Promise(r => setTimeout(r, ms));

  function findAssignmentRow(keyword) {
    // Find the row/container that contains the assignment keyword
    const rows = [...document.querySelectorAll(
      '[role="row"], [class*="assignment"], [class*="activity"], li, tr, [class*="card"], [class*="row"]'
    )];
    return rows.find(el =>
      el.innerText?.toLowerCase().includes(keyword.toLowerCase())
    );
  }

  function clickBlueArrowInRow(row) {
    if (!row) return false;

    // Strategy 1: look for a blue arrow SVG, icon, or button inside the row
    const arrowBtn = [...row.querySelectorAll(
      'button, a, [role="button"], [class*="arrow"], [class*="launch"], [class*="start"], [class*="go"], [class*="chevron"], [aria-label*="open"], [aria-label*="launch"], [aria-label*="start"], [aria-label*="begin"], [title*="open"], [title*="launch"], [title*="start"]'
    )].find(el => {
      const style = window.getComputedStyle(el);
      const html  = el.outerHTML.toLowerCase();
      // Prefer elements that look like a forward/right-pointing arrow or launch button
      return (
        html.includes('arrow') ||
        html.includes('chevron') ||
        html.includes('launch') ||
        html.includes('start') ||
        html.includes('go') ||
        html.includes('svg') ||
        html.includes('icon') ||
        style.color.includes('rgb(0') ||   // blue tones
        style.backgroundColor.includes('rgb(0')
      );
    });

    if (arrowBtn) { arrowBtn.click(); return true; }

    // Strategy 2: last anchor/button in the row (often the action button)
    const allClickable = [...row.querySelectorAll('a, button, [role="button"]')];
    if (allClickable.length > 0) {
      allClickable[allClickable.length - 1].click();
      return true;
    }

    return false;
  }

  function tryClick(keyword) {
    const row = findAssignmentRow(keyword);
    return row ? clickBlueArrowInRow(row) : false;
  }

  if (tryClick('<ASSIGNMENT KEYWORD>')) {
    await d(3000);
    return 'blue arrow clicked — no scroll needed';
  }

  for (let i = 0; i < 8; i++) {
    window.scrollBy(0, 320);
    await d(700);
    if (tryClick('<ASSIGNMENT KEYWORD>')) {
      await d(3000);
      return 'blue arrow clicked after ' + (i + 1) + ' scroll(s)';
    }
  }

  return 'assignment not found — take screenshot and ask user to confirm name';
})()
```

Replace `<ASSIGNMENT KEYWORD>` with the chapter or assignment name (e.g. "chapter 5", "smartbook 5").

**If the arrow click lands on a summary/overview page instead of questions:** look for a second blue arrow or "Begin" / "Continue" button on that page and click it before proceeding to Step 0d.

If assignment still not found after scrolling: take a screenshot, show the user, and ask them to confirm the exact assignment name visible on screen.

Wait 2–3 seconds for the SmartBook Welcome screen to load, then proceed to Step 0d.

