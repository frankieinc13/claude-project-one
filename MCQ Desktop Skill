#### 0c-ii — Click the correct course

```javascript
(async () => {
  const d = ms => new Promise(r => setTimeout(r, ms));
  const allLinks = [...document.querySelectorAll('a, button, [role="link"], [class*="course"], [class*="card"]')];
  const target = allLinks.find(el => el.innerText?.toLowerCase().includes('<COURSE KEYWORD>'));
